{
  "name": "cgraph",
  "version": "1.0.0",
  "description": "Code intelligence graph for AI agents",
  "main": "dist/cli/index.js",
  "bin": {
    "cgraph": "cgraph.js"
  },
  "scripts": {
    "build": "tsc && mkdir -p dist/web/public && cp src/web/public/index.html dist/web/public/index.html && cp node_modules/3d-force-graph/dist/3d-force-graph.min.js dist/web/public/3d-force-graph.min.js",
    "dev": "tsx src/cli/index.ts",
    "analyze": "tsx src/cli/index.ts analyze",
    "serve": "tsx src/cli/index.ts serve"
  },
  "files": [
    "cgraph.js",
    "dist/"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.12.0",
    "3d-force-graph": "^1.80.0",
    "commander": "^12.0.0",
    "express": "^4.19.0",
    "glob": "^10.4.0",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "^0.22.6",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
